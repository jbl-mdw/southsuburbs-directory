agent.klirtrak.com {
	encode gzip

	# Agent API / Widget -> Gateway

	handle /widget/v1/loader.js {
		reverse_proxy lgr_connect_gateway:4120
	}

	handle_path /widget/* {
		reverse_proxy lgr_connect_gateway:4120
	}

	handle /connect/* {
		reverse_proxy lgr_connect_gateway:4120
	}

	# Agent UI Dashboard
	handle {
		reverse_proxy lgr-dashboard:3001
	}
}


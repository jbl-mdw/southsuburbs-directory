# ============================================
# Leads2Scale WordPress Multisite
# ============================================

connect.leads2scale.com {
    encode gzip

    header @from_ssb Access-Control-Allow-Origin "https://southsuburbsbest.com"
    header @from_ssb_www Access-Control-Allow-Origin "https://www.southsuburbsbest.com"
    header @from_demo Access-Control-Allow-Origin "https://demo1.leads2scale.com"

    header Access-Control-Allow-Methods "GET, POST, OPTIONS"
    header Access-Control-Allow-Headers "Content-Type, X-Client-ID"
    header Access-Control-Allow-Credentials "true"

    @from_ssb header Origin https://southsuburbsbest.com
    @from_ssb_www header Origin https://www.southsuburbsbest.com
    @from_demo header Origin https://demo1.leads2scale.com

    @options method OPTIONS
    respond @options 204

    handle /v1/* {
        reverse_proxy lgr_connect_gateway:4120
    }

    handle /demo/* {
        reverse_proxy lgr_connect_gateway:4120
    }

    respond "connect root ok" 200
}


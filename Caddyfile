southsuburbsbest.com {
    encode gzip
    
    # 1. Named Matcher for LGR Gateway
    @gateway_paths {
        path /widget.js* /widget/* /api/widget/* /api/v1/* /v1/* /connect/*
    }
    
    handle @gateway_paths {
        header Cache-Control "no-store"
        reverse_proxy lgr_connect_gateway:4120
    }
    
    # 2. Named Matcher for Directus (Fixes Line 30 error)
    @directus_paths {
        path /directus/* /utils/* /assets/*
    }
    
    handle @directus_paths {
        reverse_proxy ssb_directus:8055
    }
    
    # 3. Main Next.js Frontend
    handle {
        reverse_proxy frontend:3000
    }
}
# 4. Independent Subdomain (Must be outside the main block)
